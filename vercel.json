{
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/auth",
      "destination": "/auth.html"
    },
    {
      "source": "/tracking",
      "destination": "/tracking.html"
    },
    {
      "source": "/crew",
      "destination": "/crew.html"
    },
    {
      "source": "/ai",
      "destination": "/ai.html"
    }
  ]
}
